// ============================================================
// Global settings (apply to all providers)
// ============================================================

// Maximum output tokens per request (default: 2000)
$config['lifeprisma_ai_max_tokens'] = 2000;

// Temperature for "None" reasoning mode (0.0 - 1.0, default: 0.5)
$config['lifeprisma_ai_temperature'] = 0.5;

// Default language for generated emails
$config['lifeprisma_ai_default_language'] = 'English';
