// ============================================================
// OPTION 2: Simple single-provider (legacy, still works)
// ============================================================
// If you only need one provider, you can use the flat config instead.
// The multi-provider config above takes priority if both are set.

// $config['lifeprisma_ai_api_key'] = '';
